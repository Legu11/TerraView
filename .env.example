# Configuration de la base de données
# Copie ce fichier en .env et adapte les valeurs à ton install MySQL/MariaDB.
# Le fichier .env est ignoré par Git (ne pas le committer).

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=0000
DB_NAME=agriculture

# Configuration de l'API Flask
API_HOST=127.0.0.1
API_PORT=5000
